generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents Document[]
}

model Document {
  id            String    @id @default(uuid())
  resiNumber    String    @unique
  clientName    String
  documentType  DocType
  fileUrl       String
  currentStatus DocStatus @default(RECEIVED)
  staffId       String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  staff     User              @relation(fields: [staffId], references: [id])
  histories TrackingHistory[]
}

model TrackingHistory {
  id          String    @id @default(uuid())
  documentId  String
  status      DocStatus
  description String?
  changedBy   String
  createdAt   DateTime  @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

enum Role {
  STAFF
  ADMIN
}

enum DocType {
  VISA
  KITAS
  PASSPORT
}

enum DocStatus {
  RECEIVED
  IN_REVIEW
  IN_PROCESS
  APPROVED
  REJECTED
  COMPLETED
}
